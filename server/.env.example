# Aspen Agent 服务配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 服务器配置 ====================
# 服务器监听地址 (0.0.0.0 表示监听所有网络接口)
ASPEN_HOST=0.0.0.0

# 服务器端口
ASPEN_SIMULATOR_PORT=6000

# 调试模式 (生产环境请设置为 False)
ASPEN_DEBUG=True

# ==================== 路径配置 ====================
# Aspen 工作基础目录 (所有文件将存储在此目录下)
# Windows 路径示例: D:/aspen 或 D:\\aspen
# Linux 路径示例: /opt/aspen
ASPEN_BASE_DIR=D:/aspen

# Aspen Plus 可执行文件路径 (可选，如果需要自动启动 Aspen Plus)
# 示例: C:/Program Files/AspenTech/Aspen Plus V12.1/GUI/Aspen Plus.exe
ASPEN_EXECUTABLE=

# ==================== SSL/HTTPS 配置 ====================
# Aspen Agent 只允许 HTTPS 启动。若以下文件不存在，启动时会自动创建固定自签名证书。
# 也可以改成受信任证书的绝对路径。
# SSL 证书文件路径 (相对于 server 目录或绝对路径)
SSL_CERT_FILE=ssl/cert.pem

# SSL 密钥文件路径 (相对于 server 目录或绝对路径)
SSL_KEY_FILE=ssl/key.pem

# 可选：为生成的证书指定 SAN 主机名/IP，多个值用逗号分隔
# ASPEN_SSL_HOSTS=localhost,127.0.0.1,my-hostname,10.10.10.20

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 其他配置 ====================
# JWT 密钥 (用于认证，请修改为随机字符串)
JWT_SECRET=your-secret-key-change-this-in-production
